# ============================================================
# Google service-account OAuth (Sheets/Gmail/Drive)
# ============================================================
# Used for backend API access via refresh_token. Set up via auth-setup.js.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ============================================================
# Login OAuth (end-user sign-in)
# ============================================================
# SEPARATE OAuth client from above — must NOT share credentials.
# Scopes used: openid email profile. No Sheets/Gmail/Drive access.
LOGIN_OAUTH_CLIENT_ID=
LOGIN_OAUTH_CLIENT_SECRET=
LOGIN_OAUTH_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated whitelist of allowed email addresses (lowercase)
ALLOWED_EMAILS=jacob@naava.no,edson@example.com

# Accountant role — these emails log in to a restricted "Regnskap" view with
# PowerOffice copy buttons (read-only, no edit/admin). They can log in even if
# not in ALLOWED_EMAILS.
ACCOUNTANT_EMAILS=regnskap@naava.no

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# ============================================================
# IVIT Webhook (existing Sliplane service)
# ============================================================
IVIT_WEBHOOK_URL=https://naavaivit.sliplane.app/webhook
IVIT_WEBHOOK_SECRET=

# ============================================================
# Server
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# Modes
# ============================================================
# TEST_MODE: routes all emails to OWNER_EMAIL/ACCOUNTANT_EMAIL only
TEST_MODE=false

# DEMO_MODE: skip external API calls, show banner; for safe demos
DEMO_MODE=false

# WEBAPP_CRON_ENABLED: turn on background jobs (scan, IVIT, reminders, weekly).
# Keep false while Apps Script runs in parallel to avoid double-processing.
WEBAPP_CRON_ENABLED=false
